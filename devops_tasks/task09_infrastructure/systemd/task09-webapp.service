[Unit]
Description=Task09
After=network-online.target
Wants=network-online.target

[Service]
User=task09
Group=task09
WorkingDirectory=/opt/task09/app
Environment="PATH=/opt/task09/venv/bin"
ExecStart=/opt/task09/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

